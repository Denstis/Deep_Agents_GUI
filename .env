# Конфигурация Deep Agents GUI
# По умолчанию настроено на работу с LM Studio (локально)

# API Ключ (заглушка для локальных моделей)
OPENAI_API_KEY=lm-studio

# Адрес локального сервера LM Studio
OPENAI_API_BASE=http://localhost:1234/v1

# Модель по умолчанию (Qwen 3.5 9B)
OPENAI_MODEL_NAME=qwen/qwen3.5-9b

# Трассировка LangSmith (отключена для локальной работы)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=deep-agents-gui-local

# Настройки безопасности
# FULL_ACCESS_COMMANDS=true  # Включить полные права (опасно)
# FULL_ACCESS_COMMANDS=false # Ограниченный режим (безопасно)
FULL_ACCESS_COMMANDS=false
